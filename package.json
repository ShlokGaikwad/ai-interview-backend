{
  "name": "ai-interview-backend",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"ts-node -r tsconfig-paths/register src/index.ts\"",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "seed": "ts-node -r tsconfig-paths/register src/scripts/seed.ts",
    "test:realtime": "ts-node -r tsconfig-paths/register src/scripts/test-realtime-connection.ts",
    "test:realtime:audioout": "ts-node -r tsconfig-paths/register src/scripts/test-realtime-audio-out.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@deepgram/sdk": "^3.9.0",
    "@livekit/rtc-node": "^0.12.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "elevenlabs": "^0.17.0",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "livekit-server-sdk": "^2.6.0",
    "mongoose": "^8.5.0",
    "nanoid": "^3.3.12",
    "openai": "^4.56.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.0"
  }
}
